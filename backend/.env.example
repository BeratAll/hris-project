# ========================================
# HRIS Backend — Ortam Değişkenleri Şablonu
# ========================================
# Bu dosyayı kopyalayıp .env.development, .env.staging veya .env.production
# adıyla kaydedin ve değerleri ortamınıza göre düzenleyin.

# ---------- UYGULAMA ----------
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ---------- PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=secretpassword
DB_NAME=hris_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- JWT ----------
JWT_SECRET=buraya-guclu-bir-secret-key-yazin-en-az-64-karakter-olmali
JWT_EXPIRES_IN=1d
JWT_COOKIE_EXPIRES_IN=1

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:5173

# ---------- ENCRYPTION (AES-256-GCM) ----------
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---------- RATE LIMITING ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------- LOG ----------
LOG_LEVEL=debug
LOG_DIR=logs
